@page "/"

<PageTitle>Ariel Mariussi — Desenvolvedor .NET Fullstack</PageTitle>

<!-- ── HERO ── -->
<section class="hero">
    <div class="site-wrapper">
        <p class="hero-label fade-in">Desenvolvedor .NET Fullstack</p>
        <h1 class="hero-name fade-in delay-1">
            Ariel<br /><span>Mariussi</span>
        </h1>
        <p class="hero-role fade-in delay-2">// C# · .NET · Blazor · REST APIs</p>
        <p class="hero-desc fade-in delay-3">
            Desenvolvedor fullstack especializado em <strong>.NET</strong> e <strong>C#</strong>.
            Construo APIs robustas, interfaces modernas com Blazor e
            soluções completas do banco de dados até a interface.
        </p>
        <div class="hero-cta fade-in delay-4">
            <a href="#projetos" class="btn btn-primary">Ver projetos →</a>
            <a href="#contato" class="btn btn-secondary">Entrar em contato</a>
        </div>
    </div>
</section>

<!-- ── STACK ── -->
<section class="stack-section" id="stack">
    <div class="site-wrapper">
        <p class="section-label">Stack técnica</p>
        <div class="stack-grid">
            @foreach (var item in _stack)
            {
                <div class="stack-item">
                    <div class="stack-dot"></div>
                    <div class="stack-item-cat">@item.Category</div>
                    <div class="stack-item-name">@item.Name</div>
                </div>
            }
        </div>
    </div>
</section>

<!-- ── PROJETOS ── -->
<section class="projects-section" id="projetos">
    <div class="site-wrapper">
        <p class="section-label">Projetos</p>

        <div class="project-card">
            <div class="project-header">
                <span class="project-number">01 / 01</span>
                <div class="project-tags">
                    <span class="tag tag-highlight">Em produção</span>
                    <span class="tag">Fullstack</span>
                </div>
            </div>
            <div class="project-body">
                <h2 class="project-title">MedReminder - Lembrete de Medicamentos</h2>
                <p class="project-desc">
                    <span class="project-title">Sobre:</span>MedReminder é um aplicativo com a função de lembrar pessoas 
                    de tomarem suas medicações. Ele é voltado mais para o publico que utiliza e passa seu tempo no computador.
                    <br />
                    <span class="project-title">Como funciona:</span> Voçê deve adicionar o seu medicamento clicando em +NOVO MEDICAMENTO,
                    adicionar seu nome ,o horario que vai tomar o remedio e salvar. Nisso sua medicacao ficara salva e voce recebera uma notificacao
                    com um aviso sonoro("beep") quando for a hora de tomar. Se quiser voce pode mudar o estado do remedio para "Tomado" para nao esquecer,
                    e quando der meia-noite o estado e reiniciado. <span class="btn-primary">***IMPORTANTE: PARA FUNCIONAR VOCE DEVE ESTAR COM A APLICACAO ABERTA NO BROWSER!!</span>Obs:Devido a estar sendo usado dominios diferentes, o logout ficou comprometido;
                    entao para se deslogar voce deve apagar os cookies no DevTools na aba Console, aba Cookies.Caso o cookie nao aparece é so atualizar a pagina.
                    <br />
                    <span class="project-title">Ferramentas utilizadas:</span> Backend(Med.Api) com ASP.NET Core Minimal API(Rest) , banco de dados PostgreSQL serverless via Neon,
                    hospedagem da API no Render ,interface consumindo os endpoints de forma reativa e
                    Frontend sendo utilizado BlazorWasm.
                </p>
                <div class="project-stack">
                    @foreach (var tech in _medTechs)
                    {
                        <span class="stack-badge">@tech</span>
                    }
                </div>
                <div class="project-links">
                    <a href="https://med-lembrete-de-remedios.vercel.app/login" target="_blank" class="btn btn-primary">
                        Site
                    </a>
                    <a href="https://med-lembretederemedios.onrender.com/swagger/index.html" target="_blank" class="btn btn-primary">
                        API ao vivo →
                    </a>
                    <a href="https://github.com/ArielMariussi" target="_blank" class="btn btn-secondary">
                        GitHub →
                    </a>
                </div>
            </div>
        </div>

    </div>
</section>

<!-- ── CONTATO ── -->
<section class="contact-section" id="contato">
    <div class="site-wrapper">
        <p class="section-label">Contato</p>
        <h2 style="font-family: var(--font-display); font-size: clamp(28px, 5vw, 48px); font-weight: 800; letter-spacing: -1px; margin-bottom: 12px;">
            Vamos conversar?
        </h2>
        <p style="color: var(--muted); font-size: 14px; max-width: 400px;">
            Aberto a oportunidades e colaborações em projetos .NET.
        </p>

        <div class="contact-grid">
            <div class="contact-item">
                <span class="contact-label">Email</span>
                <a href="mailto:arielmariussi@gmail.com">arielmariussi@gmail.com</a>
            </div>
            <div class="contact-item">
                <span class="contact-label">LinkedIn</span>
                <a href="https://www.linkedin.com/in/ariel-mariussi-dev" target="_blank">linkedin.com/in/ariel-mariussi-dev</a>
            </div>
            <div class="contact-item">
                <span class="contact-label">GitHub</span>
                <a href="https://github.com/ArielMariussi" target="_blank">github.com/ArielMariussi</a>
            </div>
            <div class="contact-item">
                <span class="contact-label">Localização</span>
                <span style="color: var(--muted);"> Curitiba - Brasil 🇧🇷</span>
            </div>
        </div>
    </div>
</section>

@code {
    private record StackItem(string Category, string Name);

    private readonly List<StackItem> _stack = new()
    {
        new("Backend",   "C# / .NET"),
        new("Backend",   "ASP.NET Core"),
        new("Backend",   "REST APIs"),
        new("Frontend",  "Blazor WASM"),
        new("Banco",     "PostgreSQL"),
        new("Banco",     "Neon (serverless)"),
        new("Cloud",     "Render"),
        new("Cloud",     "Vercel"),
        new("Versionamento", "Git / GitHub"),
    };

    private readonly List<string> _medTechs = new()
    {
        "C#", ".NET", "ASP.NET Core", "PostgreSQL", "Neon", "Render", "REST API", "Entity Framework"
    };
}
